# Dockerfile for building INSIDE the CoScientist monorepo, where the build context is the
# CoScientist repo root (mcp-servers/docker-compose.yml uses `context: ..`). For a standalone
# build (context = this repo), use the plain ./Dockerfile instead.
FROM python:3.12-slim

# RDKit / scientific stack runtime libs (slim image omits these).
RUN apt-get update && apt-get install -y --no-install-recommends \
    libxrender1 \
    libxext6 \
    libgomp1 \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN pip install uv

COPY mcp-servers/tox-antitargets-mcp-server/pyproject.toml mcp-servers/tox-antitargets-mcp-server/README.md ./
RUN uv sync --no-install-project

COPY mcp-servers/tox-antitargets-mcp-server/server ./server

ENV UV_SYSTEM_PYTHON=1
ENV TOX_ARTIFACTS_DIR=/app/artifacts
RUN mkdir -p /app/artifacts
EXPOSE 7331

CMD ["uv", "run", "--no-project", "python", "-m", "server.tox_server"]
