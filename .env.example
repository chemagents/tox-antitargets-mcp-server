# --- MCP transport ---
TOX_MCP_HOST=0.0.0.0
TOX_MCP_PORT=7331
TOX_MCP_PATH=/mcp

# --- Dataset ---
# Defaults to the CSV bundled inside the package; if missing it is downloaded from TOX_DATASET_URL.
# Uncomment to override the location:
# TOX_DATASET_PATH=/app/server/data/antitargets_LD50_affinity.csv
TOX_DATASET_URL=https://raw.githubusercontent.com/chemagents/ld50-antitargets/main/antitargets_LD50_affinity.csv

# --- Analysis parameters (defaults reproduce the paper) ---
TOX_BINDER_THRESHOLD=-7.0
TOX_TANIMOTO_THRESHOLD=0.65
TOX_MORGAN_NBITS=2048

# --- Figure artifacts ---
# Local directory (default). Set TOX_ARTIFACT_URL_BASE if the dir is served over HTTP.
TOX_ARTIFACTS_DIR=/app/artifacts
# TOX_ARTIFACT_URL_BASE=

# Optional S3-compatible storage (matches chemical-mcp-server); if set, figures are
# uploaded and returned as presigned URLs instead of local paths.
TOX_S3_ENDPOINT_URL=
TOX_S3_BUCKET_NAME=
TOX_S3_ACCESS_KEY=
TOX_S3_SECRET_KEY=
